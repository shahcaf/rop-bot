# ─────────────────────────────────────────
# Discord Bot Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Bot Token (from Discord Developer Portal → Bot → Token)
BOT_TOKEN=your_bot_token_here

# Application / Client ID (from Discord Developer Portal → General Information)
CLIENT_ID=your_client_id_here

# Guild ID (your server's ID – right-click server icon → Copy ID)
GUILD_ID=your_guild_id_here

# Your Discord User ID (for owner-only commands)
OWNER_ID=your_discord_user_id_here

# Bot Permissions Integer (8 = Administrator)
PERMISSIONS=8
